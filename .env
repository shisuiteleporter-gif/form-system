# Configuracao do Banco
DATABASE_URL=sqlite:///./data/forms.db

# Configuracao E-Docs (preencher quando tiver as credenciais)
EDOCS_CLIENT_ID=
EDOCS_CLIENT_SECRET=
EDOCS_AMBIENTE=treinamento
EDOCS_SCOPE=api-sigades-consultar api-sigades-documento api-sigades-encaminhamento api-sigades-processo

# Configuracao do Sistema
